# ========================================================
# ClipWise — Production Environment Variables (Backend)
# ========================================================
# HOW TO USE: 
# Copy these keys into your Railway / Render Dashboard.
# Do NOT commit your actual .env.production file to git.

# --------------------------------------------------------
# 1. FastAPI App Settings
# --------------------------------------------------------
APP_NAME="ClipWise API Production"
APP_VERSION="1.0.0"
BACKEND_DEBUG=False
CORS_ORIGINS="https://clipwise.app,https://www.clipwise.app"

# --------------------------------------------------------
# 2. Supabase (Database & Auth & Storage)
# --------------------------------------------------------
# Get from: Supabase Dashboard -> Project Settings -> API
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_ANON_KEY="your-anon-key-here"
# Service Role Key is CRITICAL for Celery Workers (Bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_JWT_SECRET="your-jwt-secret-from-dashboard"

# --------------------------------------------------------
# 3. Upstash Redis (Celery Broker & Backend)
# --------------------------------------------------------
# Get from: Upstash Dashboard -> Redis -> Connect
# Use the "rediss://" (secure) URL for production.
REDIS_URL="rediss://default:your-password@your-endpoint.upstash.io:6379"
CELERY_BROKER_URL="rediss://default:your-password@your-endpoint.upstash.io:6379"
CELERY_RESULT_BACKEND="rediss://default:your-password@your-endpoint.upstash.io:6379"

# --------------------------------------------------------
# 4. OpenAI (Whisper & GPT-4o)
# --------------------------------------------------------
# Get from: platform.openai.com
OPENAI_API_KEY="sk-proj-..."

# --------------------------------------------------------
# 5. Stripe Payments
# --------------------------------------------------------
# Get from: Stripe Dashboard -> Developers -> API Keys
STRIPE_API_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
FRONTEND_URL="https://clipwise.app"
